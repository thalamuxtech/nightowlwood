rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Staff allowlist — public signup is enabled on this project, so a signed-in
    // session alone is NOT proof of staff. Only these exact accounts are staff.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in ['admin@nightowl.com.ng'];
    }

    function validSubmission(required) {
      return request.resource.data.keys().hasAll(required.concat(['status', 'createdAt']))
        && request.resource.data.status == 'new'
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() < 200
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() < 320
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() < 5000;
    }

    // Quote requests
    match /inquiries/{id} {
      allow create: if validSubmission(['name', 'email', 'message']);
      allow read, update, delete: if isAdmin();
    }

    // Internship applications
    match /internApplications/{id} {
      allow create: if validSubmission(['name', 'email', 'message', 'area']);
      allow read, update, delete: if isAdmin();
    }

    // General contact messages
    match /contacts/{id} {
      allow create: if validSubmission(['name', 'email', 'message']);
      allow read, update, delete: if isAdmin();
    }

    // Newsletter subscribers — create-only (no overwrite), staff manage.
    match /subscribers/{id} {
      allow create: if request.resource.data.keys().hasAll(['email', 'createdAt'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() < 320;
      allow read, update, delete: if isAdmin();
    }

    // Blog posts — public may read published; staff write.
    match /posts/{id} {
      allow read: if resource.data.published == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Gallery items managed from the dashboard; public may read published ones.
    match /workItems/{id} {
      allow read: if resource.data.published == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Site settings: public read, staff write.
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
