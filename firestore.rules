rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null;
    }

    // Public quote requests: anyone may create a well-formed inquiry;
    // only signed-in staff may read, update, or delete.
    match /inquiries/{id} {
      allow create: if
        request.resource.data.keys().hasAll(['name', 'email', 'message', 'status', 'createdAt']) &&
        request.resource.data.status == 'new' &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() < 200 &&
        request.resource.data.email is string &&
        request.resource.data.email.size() > 3 &&
        request.resource.data.email.size() < 320 &&
        request.resource.data.message is string &&
        request.resource.data.message.size() > 0 &&
        request.resource.data.message.size() < 5000;
      allow read, update, delete: if isAdmin();
    }

    // Gallery items managed from the dashboard; public may read published ones.
    match /workItems/{id} {
      allow read: if resource.data.published == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Site settings: public read, staff write.
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
