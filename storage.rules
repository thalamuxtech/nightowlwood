rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isStaff() {
      return request.auth != null
        && request.auth.token.email in ['admin@nighowl.com.ng'];
    }

    function validImage() {
      return request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Work gallery images: public read, staff-only write, images only, max 10 MB.
    match /work/{file} {
      allow read: if true;
      allow write: if isStaff() && validImage();
    }

    // Blog post images: public read, staff-only write.
    match /blog/{file} {
      allow read: if true;
      allow write: if isStaff() && validImage();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
